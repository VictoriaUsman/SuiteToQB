# App
APP_SECRET_KEY=change-this-to-a-random-secret-key-32-chars-min
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./accountingsuite.db

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# QuickBooks Advanced (OAuth 2.0)
QB_CLIENT_ID=your_quickbooks_client_id
QB_CLIENT_SECRET=your_quickbooks_client_secret
QB_REDIRECT_URI=http://localhost:8000/api/quickbooks/callback
QB_ENVIRONMENT=sandbox
# QB_ENVIRONMENT=production

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# File uploads
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=50

# Tesseract OCR (path to tesseract executable)
TESSERACT_CMD=tesseract
